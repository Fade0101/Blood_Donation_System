            "body": {
              "mode": "raw",
              "raw": "{\n  \"nationalId\": \"12345678901234\",\n  \"name\": \"Ahmed Hassan\",\n  \"phone\": \"+966501234567\",\n  \"address\": \"Riyadh\",\n  \"offlineSyncId\": \"sync-123-abc\"\n}"
